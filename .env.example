# Legacy import path — you normally do NOT need this file.
# The web UI stores your key in wallet.json (encrypted when you set a
# password) in the OS app-data dir, NOT here. This .env is only a one-time
# convenience: if you put a PRIVATE_KEY here, the app imports it into
# wallet.json on first launch, then uses wallet.json from then on.
#
# PRIVATE_KEY is the key of the wallet that OWNS your veNFT position.
# It never leaves your computer — the app only uses it to sign
# transactions that are sent directly to Robinhood Chain.
PRIVATE_KEY=

# Optional: use your own RPC endpoint instead of the public one.
# RPC_URL=https://rpc.mainnet.chain.robinhood.com
